# === LLM / Anthropic ===
# Inserisci la tua API key reale in .env (mai committare chiavi reali)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# === Runtime flags ===
# USE_LLM: abilita chiamate LLM quando run_report=True
USE_LLM=false
# DRY_RUN: se true, salta chiamate LLM e genera spiegazioni placeholder
DRY_RUN=true
