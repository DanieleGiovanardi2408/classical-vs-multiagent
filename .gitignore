.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Jupyter ───────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data (non caricare dati sensibili su GitHub) ──────────────────
data/raw/*.csv
data/raw/*.json
data/raw/*.xlsx
data/processed/*.csv
data/processed/*.parquet

# ── Report generati a runtime ─────────────────────────────────────
reports/*.html
reports/*.pdf

